rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    match /users/{userId} {
      // Anyone authenticated can read any user
      allow read: if request.auth != null;

      // Users can fully update their own document
      allow write: if request.auth != null && request.auth.uid == userId;

      // Allow other users to update ONLY the friends array when adding themselves
      // This enables accepting friend requests
      allow update: if request.auth != null &&
                      request.auth.uid != userId &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friends']) &&
                      request.resource.data.friends.hasAll(resource.data.get('friends', [])) &&
                      request.resource.data.friends.includes(request.auth.uid);

      // Allow other users to update ONLY the coins field
      // This enables bet payouts
      allow update: if request.auth != null &&
                      request.auth.uid != userId &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['coins']);
    }

    // Bets collection
    match /bets/{betId} {
      allow read: if request.auth != null &&
                    (resource.data.creatorId == request.auth.uid ||
                     resource.data.participantId == request.auth.uid);
      allow create: if request.auth != null &&
                      request.resource.data.creatorId == request.auth.uid;
      allow update: if request.auth != null &&
                      (resource.data.creatorId == request.auth.uid ||
                       resource.data.participantId == request.auth.uid);
      allow delete: if request.auth != null &&
                      resource.data.creatorId == request.auth.uid;
    }

    // Friend requests collection
    match /friendRequests/{requestId} {
      // Users can read requests where they're the sender or recipient
      allow read: if request.auth != null &&
                    (resource.data.fromUserId == request.auth.uid ||
                     resource.data.toUserId == request.auth.uid);

      // Users can create requests where they're the sender
      allow create: if request.auth != null &&
                      request.resource.data.fromUserId == request.auth.uid;

      // Users can update requests where they're the recipient (accepting/declining)
      allow update: if request.auth != null &&
                      resource.data.toUserId == request.auth.uid;
    }
  }
}
